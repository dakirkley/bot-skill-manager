# Environment Variables

# Database (PostgreSQL required for production)
# For local dev, you can use: postgresql://user:password@localhost:5432/bot_skill_manager
# For Vercel + Neon: postgresql://user:pass@host.neon.tech/dbname
DATABASE_URL="postgresql://user:password@localhost:5432/bot_skill_manager"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
